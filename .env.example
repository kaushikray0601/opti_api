DJANGO_DEBUG=True
ENV_MODE=dev
DJANGO_SETTINGS_MODULE=optimizer_api.settings
PYTHONUNBUFFERED=1

OPTIMIZER_API_KEY=replace-with-local-api-key
DJANGO_SECRET_KEY=replace-with-local-django-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,optimizer-api-web,optimizer-api-nginx
DJANGO_CSRF_TRUSTED_ORIGINS=
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

CELERY_BROKER_URL_DEV=redis://localhost:6379/0
CELERY_RESULT_BACKEND_DEV=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_EAGER_PROPAGATES=True
CELERY_TASK_STORE_EAGER_RESULT=True
CELERY_BROKER_URL_EAGER=memory://
CELERY_RESULT_BACKEND_EAGER=cache+memory://

CELERY_BROKER_URL_DOCKER=redis://optimizer_api_redis:6379/0
CELERY_RESULT_BACKEND_DOCKER=redis://optimizer_api_redis:6379/0

# host_app should use one of these, depending on how this repo is running:
# VS Code / runserver: http://127.0.0.1:8000/api/optimizer/submit/
# Docker + nginx:      http://127.0.0.1:8080/api/optimizer/submit/
